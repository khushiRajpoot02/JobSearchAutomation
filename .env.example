# ── Copy this file to .env for local testing ──────────────────────────────
# NEVER commit .env to git (it's in .gitignore)

# Candidate profile
CANDIDATE_NAME=Your Full Name
CANDIDATE_LINKEDIN=linkedin.com/in/your-profile
YEARS_OF_EXPERIENCE=5

# SerpAPI — https://serpapi.com  (free: 250 searches/week)
SERPAPI_KEY=your_serpapi_key_here

# Google Gemini — https://aistudio.google.com/app/apikey  (free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets — ID from the spreadsheet URL
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account credentials (full JSON as a single line)
# 1. Go to Google Cloud Console → IAM & Admin → Service Accounts
# 2. Create a service account, add "Editor" role
# 3. Keys → Add Key → JSON → download
# 4. Share your Google Sheet with the service account email
# 5. Paste the ENTIRE JSON content here (minified / single line)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
